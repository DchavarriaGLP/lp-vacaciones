NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx   # solo server-side, nunca exponer al cliente

# =========================================
# Microsoft Entra ID (Azure AD)
# =========================================
# Provider configurado en Supabase Dashboard > Authentication > Providers > Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# =========================================
# App
# =========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
