# =========================================
# Supabase (usado SOLO como base de datos)
# =========================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
# Service role: solo server-side. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# =========================================
# Sesión / Auth propio (cookie HMAC-SHA256)
# =========================================
# Obligatorio en producción. Mínimo 16 caracteres aleatorios.
# Generar con: openssl rand -base64 32
SESSION_SECRET=change-me-with-a-long-random-string

